@{
    ViewData["Title"] = "Contact";
}

<h1>Contact</h1>

<form id="contactForm" asp-action="Index" method="post" novalidate>
    @Html.AntiForgeryToken()
    
    <div class="hp" aria-hidden="true">
        <label for="website">Laat dit veld leeg</label>
        <input type="text" id="website" name="website" value="" tabindex="-1" autocomplete="off" />
    </div>
    
    <div>
        <label for="Name">Naam</label>
        <input id="Name" name="Name" placeholder="Naam" aria-describedby="nameErr" />
        <div id="nameErr" class="error" aria-live="polite"></div>
    </div>
    
    <div>
        <label for="Email">E-mail</label>
        <input id="Email" name="Email" type="email" placeholder="naam@domein.nl" aria-describedby="emailErr" />
        <div id="emailErr" class="error" aria-live="polite"></div>
    </div>
    
    <div>
        <label for="Subject">Onderwerp</label>
        <input id="Subject" name="Subject" placeholder="Onderwerp" />
    </div>
    
    <div>
        <label for="Message">Bericht</label>
        <textarea id="Message" name="Message" rows="5" placeholder="Je bericht" aria-describedby="msgErr"></textarea>
        <div id="msgErr" class="error" aria-live="polite"></div>
    </div>
    
    <div id="liveStatus" aria-live="polite"></div>
    
    <button type="submit" class="send-button">
        Versturen
    </button>
</form>